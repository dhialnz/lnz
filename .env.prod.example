# ─────────────────────────────────────────────────────────────────────────────
# Alphenzi — Production Environment Variables
#
# Copy this file to .env and fill in all values before running production.
# NEVER commit .env with real values to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains ──────────────────────────────────────────────────────────────────
# Root domain. Caddy will serve:
#   alphenzi.com       → static landing page (landing/index.html)
#   app.alphenzi.com   → Next.js app
# Both get automatic Let's Encrypt HTTPS certificates.
ALPHENZI_DOMAIN=alphenzi.com

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=lnz
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=lnz_db

# ── Security ─────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_64char_random_secret

# Must be exactly 32 bytes. Generate: python -c "import secrets; print(secrets.token_urlsafe(24)[:32])"
FILE_ENCRYPTION_KEY=CHANGE_ME_32_bytes_exactly_here!

# Optional: set to lock the API behind a key. Leave blank to disable.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
LNZ_API_KEY=

# ── AI Providers ─────────────────────────────────────────────────────────────
# "auto" tries Gemini → OpenAI → deterministic fallback
# "deterministic" for no LLM usage (safe default, no API keys required)
LNZ_AI_PROVIDER=auto

LNZ_GEMINI_API_KEY=CHANGE_ME_gemini_key
LNZ_GEMINI_MODEL=gemini-2.5-flash

LNZ_OPENAI_API_KEY=CHANGE_ME_openai_key
LNZ_OPENAI_MODEL=gpt-4o-mini

# ── Tuning ───────────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
AI_RATE_LIMIT_PER_MINUTE=20

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set to your actual domain — multiple origins comma-separated
CORS_ORIGINS=https://app.alphenzi.com

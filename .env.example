# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=lnz
POSTGRES_PASSWORD=change_me_strong_random_password
POSTGRES_DB=lnz_db

# ── FastAPI security ────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_long_random_secret
# Must be exactly 32 bytes for AES-256. Generate with:
# python -c "import secrets; print(secrets.token_hex(16))"
FILE_ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key_here!!!

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. For production add your real domain.
CORS_ORIGINS=http://localhost:3000

# ── Upload limits ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Market data provider ───────────────────────────────────────────────────────
# "mock"  = deterministic fake data (default for local dev)
# "http"  = generic HTTP adapter (configure BASE_URL + API_KEY below)
MARKET_DATA_PROVIDER=mock
MARKET_DATA_BASE_URL=
MARKET_DATA_API_KEY=

# ── News provider ──────────────────────────────────────────────────────────────
# "live"  = live RSS/web fetch (default)
# "mock"  = deterministic fake headlines
NEWS_PROVIDER=live
NEWS_BASE_URL=
NEWS_API_KEY=

# ── Next.js public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_WEBHOOK_SECRET=whsec_...

# ── AI provider ────────────────────────────────────────────────────────────────
# AI_PROVIDER: auto | gemini | openai | deterministic
# "auto"         = prefer Gemini (cheaper), fall back to OpenAI, then deterministic
# "deterministic" = no LLM calls; rule-based only (free)
LNZ_AI_PROVIDER=auto

# Gemini (recommended — generous free tier)
# Get key at: https://aistudio.google.com/app/apikey
LNZ_GEMINI_API_KEY=
LNZ_GEMINI_MODEL=gemini-2.5-flash
LNZ_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# OpenAI (optional — used if Gemini key absent in auto mode)
# Get key at: https://platform.openai.com/api-keys
LNZ_OPENAI_API_KEY=
LNZ_OPENAI_MODEL=gpt-4o-mini
# Override per-task (leave blank to use LNZ_OPENAI_MODEL for all tasks)
LNZ_OPENAI_MODEL_CHAT=
LNZ_OPENAI_MODEL_INSIGHTS=
LNZ_OPENAI_MODEL_DASHBOARD=
LNZ_OPENAI_MODEL_NEWS=
LNZ_OPENAI_BASE_URL=https://api.openai.com/v1

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY REMINDERS
# - Never commit your real .env file — it is in .gitignore for a reason.
# - Rotate keys immediately if they are ever exposed (e.g. pushed to git).
# - Use strong random values for SECRET_KEY and FILE_ENCRYPTION_KEY in prod.
# - Use a dedicated secret manager (AWS Secrets Manager, Vault) for production.
# ─────────────────────────────────────────────────────────────────────────────

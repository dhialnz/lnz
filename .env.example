# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=lnz
POSTGRES_PASSWORD=lnz_dev_password
POSTGRES_DB=lnz_db

# ── FastAPI ────────────────────────────────────────────────────────────────────
# Change these in production!
SECRET_KEY=dev-secret-key-change-in-production
# Must be exactly 32 bytes for AES-256
FILE_ENCRYPTION_KEY=dev-file-key-32-bytes-exactly!!

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Upload limits ──────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Market data provider ───────────────────────────────────────────────────────
# "mock" uses deterministic fake data (default for dev)
# "http" uses the generic HTTP adapter configured below
MARKET_DATA_PROVIDER=mock
MARKET_DATA_BASE_URL=
MARKET_DATA_API_KEY=

# ── News provider ──────────────────────────────────────────────────────────────
NEWS_PROVIDER=live
NEWS_BASE_URL=
NEWS_API_KEY=

# ── Next.js public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional AI provider
# AI_PROVIDER: auto | gemini | openai | deterministic
LNZ_AI_PROVIDER=openai

# Gemini (recommended free/default in auto mode)
LNZ_GEMINI_API_KEY=
LNZ_GEMINI_MODEL=gemini-2.5-flash
LNZ_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# OpenAI (optional fallback/alternative)
LNZ_OPENAI_API_KEY=
LNZ_OPENAI_MODEL=gpt-4o-mini
LNZ_OPENAI_MODEL_CHAT=
LNZ_OPENAI_MODEL_INSIGHTS=
LNZ_OPENAI_MODEL_DASHBOARD=
LNZ_OPENAI_MODEL_NEWS=
LNZ_OPENAI_BASE_URL=https://api.openai.com/v1
